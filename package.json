{
  "name": "designx",
  "version": "1.0.0",
  "description": "面向系统设计人员和模块负责人的本地研发治理工作台",
  "author": "DesignX",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer": "vite --host 127.0.0.1",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "npm run build && playwright test",
    "icon:generate": "node scripts/generate-icon.mjs",
    "build": "npm run typecheck && electron-vite build",
    "package:win": "npm run build && electron-builder --win nsis portable --x64 --config build/electron-builder.yml",
    "package:verify": "node scripts/verify-package.mjs"
  },
  "dependencies": {
    "lucide-react": "1.25.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "picomatch": "^4.0.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/picomatch": "^4.0.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "10.0.3",
    "docx": "^9.7.1",
    "electron": "43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.35.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "wait-on": "9.0.10"
  }
}
